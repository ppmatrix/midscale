# Midscale MagicDNS — CoreDNS Configuration
#
# This Corefile is dynamically configured to serve zone files
# generated by the Midscale backend. The backend writes zone files
# to /etc/coredns/zones/ and triggers a reload via SIGUSR1.
#
# For production, customize this file with proper ACLs, logging,
# and forwarders for upstream resolution.

.:53 {
    # Log all DNS queries
    log

    # Serve errors
    errors

    # Health check endpoint
    health

    # Prometheus metrics
    prometheus :9153

    # Forward non-midscale queries to upstream resolvers
    forward . /etc/resolv.conf {
        max_concurrent 1000
    }

    # Cache responses
    cache 30

    # Load dynamically generated zone files
    file /etc/coredns/zones/*.zone

    # Only allow queries from WireGuard networks
    # acl {
    #     allow net 10.0.0.0/8
    #     allow net 172.16.0.0/12
    #     allow net 192.168.0.0/16
    #     block
    # }
}

# Bind specifically on the WireGuard interface for internal DNS
# This can be uncommented for split-DNS configurations:
# wg.midscale:53 {
#     file /etc/coredns/zones/*.zone
#     log
#     errors
# }
