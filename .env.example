# Midscale Configuration
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://midscale:midscale@postgres:5432/midscale

# Redis (for event bus, optional — falls back to in-memory)
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=generate-a-real-secret-key-with-openssl-rand-hex-32
ENCRYPTION_KEY=

# WireGuard
WIREGUARD_INTERFACE=wg0
WIREGUARD_PORT=51820
WIREGUARD_SERVER_ENDPOINT=your-server-public-ip-or-domain
WIREGUARD_BINARY=wg
WIREGUARD_TOPOLOGY=star

# WireGuard Controller (reconciliation loop)
WG_CONTROLLER_ENABLED=true
WG_CONTROLLER_INTERVAL_SECONDS=30

# MagicDNS / CoreDNS
DNS_ENABLED=false
DNS_DOMAIN=wg.midscale
DNS_ZONES_PATH=/etc/coredns/zones
DNS_COREDNS_RELOAD_CMD=
DNS_DEFAULT_TTL=300

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_MAX=120
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_REGISTER_MAX=20
RATE_LIMIT_REGISTER_WINDOW_SECONDS=60
RATE_LIMIT_HEARTBEAT_MAX=60
RATE_LIMIT_HEARTBEAT_WINDOW_SECONDS=60
RATE_LIMIT_WEBSOCKET_MAX=30
RATE_LIMIT_WEBSOCKET_WINDOW_SECONDS=60
RATE_LIMIT_ADMIN_MAX=60
RATE_LIMIT_ADMIN_WINDOW_SECONDS=60

# Stale Device Cleanup
STALE_DEVICE_DAYS=7

# App
DEBUG=false
CORS_ORIGINS=["http://localhost:5177","http://localhost:8000","http://10.10.77.229:80","http://10.10.77.229:8000"]
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
