# Midscale daemon configuration
# Copy to /etc/midscaled/midscaled.env

# Midscale server URL (required)
MIDSCALE_SERVER_URL=http://10.0.0.1:8000

# Pre-auth key for device registration (required for first run)
MIDSCALE_PREAUTH_KEY=

# Device name (defaults to hostname)
MIDSCALE_DEVICE_NAME=

# WireGuard interface name
MIDSCALE_INTERFACE=midscale0

# Polling interval in seconds
MIDSCALE_POLL_INTERVAL=30

# Heartbeat interval in seconds
MIDSCALE_HEARTBEAT_INTERVAL=60

# Endpoint check interval in seconds
MIDSCALE_ENDPOINT_INTERVAL=120

# Enable debug logging
MIDSCALE_DEBUG=false

# Advertised subnet routes (comma-separated CIDRs, requires admin approval)
# Example: MIDSCALE_ADVERTISED_ROUTES=192.168.1.0/24,10.0.0.0/16
MIDSCALE_ADVERTISED_ROUTES=
